VITE_APP_NAME="Absensi TP PKK Balangan"

# Kosongkan untuk mode single-port/same-origin:
# - http://localhost:5173 saat Vite dev proxy dipakai
# - http://localhost:8088 saat lewat Nginx/Apache lokal
# - https://domain-production saat sudah deploy
#
# Isi hanya bila frontend harus memanggil backend langsung, misalnya:
# VITE_API_URL=http://localhost:8000
VITE_API_URL=

VITE_REVERB_APP_KEY=
# Kosongkan agar mengikuti hostname dan protokol browser.
VITE_REVERB_HOST=
VITE_REVERB_PORT=
VITE_REVERB_SCHEME=
