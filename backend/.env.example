APP_NAME="Absensi TP PKK Balangan"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8088,http://127.0.0.1:8088

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Makassar

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

HASH_DRIVER=argon2id

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tppkk_absensi
DB_USERNAME=tppkk_app
DB_PASSWORD=
DB_TIMEZONE=Asia/Makassar

# Opsional: dipakai oleh `pnpm setup:database` untuk membuat database/user
# bila database belum tersedia. Jika database sudah dibuat manual, bagian ini
# boleh dibiarkan kosong.
DB_CREATE_DATABASE=true
# Set true bila admin database lokal hanya bisa dipakai lewat sudo
# contoh: sudo -u postgres psql atau sudo mysql.
DB_ADMIN_USE_SUDO=false
# PostgreSQL: postgres, MariaDB/MySQL: root
DB_ADMIN_USERNAME=
DB_ADMIN_PASSWORD=
# PostgreSQL biasanya memakai database admin "postgres".
DB_ADMIN_DATABASE=postgres

# Alternatif PostgreSQL:
# DB_CONNECTION=pgsql
# DB_PORT=5432
# DB_DATABASE=tppkk_absensi
# DB_USERNAME=tppkk_app
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:8088,127.0.0.1:8088

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

SEED_ADMIN_LOGIN_ID=admin
SEED_ADMIN_PASSWORD=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
