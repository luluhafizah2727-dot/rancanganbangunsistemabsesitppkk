APP_NAME="Absensi TP PKK Balangan"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8088,http://127.0.0.1:8088

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Makassar
APP_MAINTENANCE_DRIVER=file

HASH_DRIVER=argon2id

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MariaDB/MySQL adalah pilihan utama. PostgreSQL juga didukung.
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tppkk_absensi
DB_USERNAME=tppkk_app
DB_PASSWORD=
DB_TIMEZONE=Asia/Makassar

# Dipakai `pnpm setup:database` bila database/user belum tersedia.
DB_CREATE_DATABASE=true
DB_ADMIN_USE_SUDO=false
DB_ADMIN_USERNAME=root
DB_ADMIN_PASSWORD=
DB_ADMIN_DATABASE=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Kosong/null membuat cookie hanya berlaku pada host yang sedang dibuka.
SESSION_DOMAIN=null
# auto: Secure pada HTTPS dan non-Secure pada HTTP jaringan lokal.
SESSION_SECURE_COOKIE=auto
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:8088,127.0.0.1:8088
TRUSTED_PROXIES=127.0.0.1,::1

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

SEED_ADMIN_LOGIN_ID=admin
SEED_ADMIN_PASSWORD=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Frontend membaca file root yang sama.
VITE_APP_NAME="Absensi TP PKK Balangan"
VITE_API_URL=
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=
VITE_REVERB_PORT=
VITE_REVERB_SCHEME=
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173
VITE_ALLOWED_HOSTS=
